{
  "extends": [
    "config:base"
  ],
  "labels": ["type: dependency upgrade"],
  "packageRules": [
    {
      "matchUpdateTypes": ["major"],
      "enabled": false
    },
    {
      "matchPackagePatterns": ["*"],
      "allowedVersions": "!/SNAPSHOT$/"
    },
    {
      "matchPackagePatterns": [
        "^org\\.apache\\.groovy"
      ],
      "groupName": "groovy monorepo"
    },
    {
      "matchPackageNames": [
        "org.apache.grails:grails-bom"
      ],
      "groupName": "grails monorepo"
    }
  ]
}